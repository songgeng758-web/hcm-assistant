# ============================================
# HCM 实施助手 · Git 忽略规则
# ============================================

# ===== 业务数据（敏感，绝对不能上传） =====
backend/data/uploads/*
backend/data/outputs/*
!backend/data/uploads/.gitkeep
!backend/data/outputs/.gitkeep

# 任何位置的 Excel/CSV 数据文件（防止误存）
# 注意：templates/ 下的模板文件是程序生成的标准模板，允许保留
*.xlsx
*.xls
*.csv
!backend/data/templates/*.xlsx
!backend/data/demo/*.xlsx

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/venv/
backend/env/
.venv/
.python-version

# pytest
.pytest_cache/
.coverage
htmlcov/
.tox/

# Python 包构建
build/
dist/
*.egg-info/

# ===== Node.js / 前端 =====
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
*.local

# ===== 数据库 =====
*.db
*.sqlite
*.sqlite3

# ===== 环境变量配置 =====
.env
.env.local
.env.*.local

# ===== IDE & 编辑器 =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== 操作系统 =====
.DS_Store
Thumbs.db
desktop.ini

# ===== 日志 =====
*.log
logs/
npm-debug.log*
yarn-debug.log*

# ===== 项目临时文件 =====
*.tmp
*.bak